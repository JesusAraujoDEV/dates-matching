generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoCita {
  esperando_pareja
  muerte_subita
  finalizada
}

model User {
  id       Int    @id @default(autoincrement())
  nombre   String
  telefono String
  password String
}

model Cita {
  id                  Int        @id @default(autoincrement())
  fecha               DateTime
  tipo_cita           String
  estado              EstadoCita @default(esperando_pareja)
  swipes_jesus_peliculas Json     @default("[]")
  swipes_jesus_comidas   Json     @default("[]")
  swipes_piera_peliculas Json     @default("[]")
  swipes_piera_comidas   Json     @default("[]")
  peliculas_match     Json       @default("[]")
  comidas_match       Json       @default("[]")
  voto_jesus_pelicula String?
  voto_jesus_comida   String?
  voto_piera_pelicula String?
  voto_piera_comida   String?
  resultado_pelicula  String?
  resultado_comida    String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model CatalogoPelicula {
  id        Int      @id @default(autoincrement())
  titulo    String
  tmdb_id   String?
  poster_url String
  createdAt DateTime @default(now())
}

model CatalogoComida {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String
  imagen_url  String?
  createdAt   DateTime @default(now())
}
